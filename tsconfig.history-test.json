{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "./node_modules/.tmp/history-tests",
    "rootDir": "./src",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.history-test.tsbuildinfo",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": [
    "src/types/firestore.ts",
    "src/utils/assignment-history.ts",
    "src/utils/assignment-history.test.ts"
  ]
}
