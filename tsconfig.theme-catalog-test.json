{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": "./node_modules/.tmp/theme-catalog-tests",
    "rootDir": "./src",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.theme-catalog-test.tsbuildinfo",
    "types": ["node"],
    "verbatimModuleSyntax": true
  },
  "include": [
    "src/lib/theme-categories.ts",
    "src/utils/theme-catalog-import.ts",
    "src/utils/theme-catalog-import.test.ts"
  ],
  "exclude": []
}
