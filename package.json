{
  "name": "discursos",
  "private": true,
  "version": "1.2.31",
  "type": "module",
  "scripts": {
    "dev": "node scripts/bump-version.mjs && vite",
    "build": "vite build",
    "lint": "eslint .",
    "typecheck": "tsc -b",
    "test:history": "tsc -p tsconfig.history-test.json && node --test %cd%/node_modules/.tmp/history-tests/utils/assignment-history.test.js",
    "test:dashboard": "tsc -p tsconfig.dashboard-test.json && node --test %cd%/node_modules/.tmp/dashboard-tests/utils/dashboard.test.js",
    "test:notifications": "tsc -p tsconfig.notifications-test.json && node --test %cd%/node_modules/.tmp/notifications-tests/utils/assignment-notifications.test.js %cd%/node_modules/.tmp/notifications-tests/utils/notification-sync.test.js",
    "test:calendar-sync": "tsc -p tsconfig.calendar-sync-test.json && node --test %cd%/node_modules/.tmp/calendar-sync-tests/google-calendar-sync.test.js",
    "test:themes-catalog": "tsc -p tsconfig.theme-catalog-test.json && node --test %cd%/node_modules/.tmp/theme-catalog-tests/utils/theme-catalog-import.test.js",
    "typecheck:worker": "tsc -p tsconfig.worker.json",
    "verify": "npm run typecheck && npm run typecheck:worker && npm run lint && npm run test:history && npm run test:dashboard && npm run test:notifications && npm run test:calendar-sync && npm run test:themes-catalog && npm run build",
    "admin:grant": "node scripts/set-firebase-admin-claim.mjs",
    "admin:bootstrap": "node scripts/bootstrap-admin-access.mjs",
    "congregations:remove-zip-code": "node scripts/remove-congregation-zip-code.mjs",
    "speakers:normalize-statuses": "node scripts/normalize-speaker-statuses.mjs",
    "preview": "vite preview",
    "deploy:worker": "npm run typecheck:worker && npm run test:calendar-sync && npx wrangler deploy --config workers/email-automation/wrangler.jsonc --keep-vars",
    "worker:deploy": "npm run deploy:worker",
    "deploy:firestore": "node scripts/bump-version.mjs && firebase deploy --only firestore:rules,firestore:indexes",
    "deploy:hosting": "node scripts/bump-version.mjs && npm run verify && firebase deploy --only hosting",
    "deploy:all": "node scripts/bump-version.mjs && npm run verify && firebase deploy --only hosting,firestore:rules,firestore:indexes"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-query": "^5.100.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.14.0",
    "lucide-react": "^1.17.0",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.77.0",
    "react-router-dom": "^7.16.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-tools": "^15.19.0",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.12"
  }
}
